# Environment Variables — Orchestrator MVP

# Hermes Bridge (local)
HERMES_BRIDGE_URL=http://127.0.0.1:18792
HERMES_TASK_ENDPOINT=/v1/task
HERMES_RESULT_ENDPOINT=/v1/result

# Orchestrator Server
ORCHESTRATOR_HOST=127.0.0.1
ORCHESTRATOR_PORT=18793

# LLM (optional — for LLM-based classifier/planner nodes)
OPENAI_API_KEY=sk-...
# Or use Groq for lower cost:
# GROQ_API_KEY=gsk_...
# LLM_PROVIDER=groq

# Worker settings
WORKER_TIMEOUT_SECONDS=120
MAX_RETRIES=2

# Logging
LOG_LEVEL=INFO
LOG_DIR=/var/log/orchestrator

# Data dirs
STATE_DIR=/var/lib/orchestrator
